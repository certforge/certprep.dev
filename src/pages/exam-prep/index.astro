---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DomainDetails from "../../components/DomainDetails.astro";
import { tracks } from "../../data/tracks";
import { examPrepIndexStructuredData } from "../../lib/structured-data";
---

<BaseLayout
  title="CertPrep | Exam Blueprints"
  description="Certification exam blueprint pages covering domain weights, focus areas, and direct links into each CertPrep repository."
  keywords={["exam blueprint", "certification study guide", "domain weights", "certification labs"]}
  structuredData={examPrepIndexStructuredData()}
>
  <section class="hero">
    <div>
      <span class="tag">Exam prep help</span>
      <h1>Blueprints for every track</h1>
      <p>
        These pages map directly to each exam blueprint so you can prioritize domains, follow the repo structure, and
        jump into the right labs first.
      </p>
    </div>
  </section>

  {tracks.map((track) => (
    <DomainDetails track={track} />
  ))}
</BaseLayout>
