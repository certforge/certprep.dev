---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DomainDetails from "../../components/DomainDetails.astro";
import { tracks } from "../../data/tracks";

const track = tracks.find((item) => item.id === "gh-100");
---

<BaseLayout title="CertPrep | GH-100 Exam Blueprint" description="GH-100 domain blueprint and prep assets.">
  {track ? (
    <DomainDetails track={track} />
  ) : (
    <p>Track not found.</p>
  )}
</BaseLayout>
