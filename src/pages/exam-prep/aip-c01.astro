---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DomainDetails from "../../components/DomainDetails.astro";
import { tracks } from "../../data/tracks";

const track = tracks.find((item) => item.id === "aip-c01");
---

<BaseLayout title="CertPrep | AIP-C01 Exam Blueprint" description="AIP-C01 domain blueprint and prep assets.">
  {track ? (
    <DomainDetails track={track} />
  ) : (
    <p>Track not found.</p>
  )}
</BaseLayout>
