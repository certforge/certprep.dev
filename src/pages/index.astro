---
import BaseLayout from "../layouts/BaseLayout.astro";
import TrackCard from "../components/TrackCard.astro";
import { tracks } from "../data/tracks";
import { valueProps } from "../data/value-props";

const totalDomains = tracks.reduce((sum, track) => sum + track.domains.length, 0);
const totalLabs = tracks.reduce((sum, track) => sum + track.labs.length, 0);
---

<BaseLayout title="CertPrep | Community-Driven Certification Labs" description="Modern certification prep for engineers. Domain-weighted study guides, runnable labs, and a community that keeps every track exam-current.">
  <section class="hero">
    <div class="hero-grid">
      <div>
        <span class="tag">Community-powered learning</span>
        <h1>Study like a practitioner, not a test taker.</h1>
        <p>
          CertPrep is a shared library of certification tracks built for engineers who learn by building. Each repo mirrors
          the official blueprint with weighted domain guides, runnable labs, and quick-start references you can fork into
          your own workflow.
        </p>
        <div class="hero-actions">
          <a class="button" href="https://github.com/certforge" target="_blank" rel="noreferrer">Explore GitHub</a>
          <a class="button secondary" href="#tracks">View Tracks</a>
        </div>
      </div>
      <div class="hero-panel">
        <div>
          <strong style="font-family:var(--font-display); font-size:1.05rem;">Learning loop</strong>
          <p style="margin:0.4rem 0 0; color:var(--text-muted);">
            Read a domain brief → run the matching lab → review with a mock question. Repeat until confident.
          </p>
        </div>
        <div class="hero-metrics">
          <div class="metric">
            <span class="metric-value">{tracks.length}</span>
            <span class="metric-label">Active certification tracks</span>
          </div>
          <div class="metric">
            <span class="metric-value">{totalDomains}</span>
            <span class="metric-label">Mapped exam domains</span>
          </div>
          <div class="metric">
            <span class="metric-value">{totalLabs}</span>
            <span class="metric-label">Hands-on labs & scripts</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="tracks">
    <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
      <div>
        <p class="tag" style="margin-bottom:0.5rem;">Certification tracks</p>
        <h2 class="section-title" style="margin:0;">Choose your next blueprint</h2>
        <p style="color:var(--text-muted); max-width:680px;">
          Every track links straight to the underlying repo so you can audit the curriculum, run the labs, and contribute
          improvements when the official objectives change.
        </p>
      </div>
      <a class="button secondary" href="https://github.com/orgs/certforge/discussions" target="_blank" rel="noreferrer">Request a track</a>
    </div>
    <div class="grid">
      {tracks.map((track) => (
        <TrackCard track={track} />
      ))}
    </div>
  </section>

  <section style="margin-top:3rem;">
    <p class="tag" style="margin-bottom:0.5rem;">Exam prep help</p>
    <h2 class="section-title" style="margin:0;">Go straight to the blueprint</h2>
    <p style="color:var(--text-muted); max-width:720px;">
      Each exam has its own blueprint page with domain weights, focus areas, and direct links into the repo. Pick the
      exam you are preparing for and jump straight in.
    </p>
    <div style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-top:1rem;">
      {tracks.map((track) => (
        <a class="button secondary" href={`/exam-prep/${track.id}`}>{track.examCode}</a>
      ))}
      <a class="button" href="/exam-prep">View all blueprints</a>
    </div>
  </section>

  <section id="toolkit" style="margin-top:3rem;">
    <p class="tag" style="margin-bottom:0.5rem;">Prep toolkit</p>
    <h2 class="section-title">All the prep assets, already curated</h2>
    <p style="color:var(--text-muted); max-width:720px;">
      Each track includes runnable labs, scripts, mock exams, and quick references so you can move from reading to doing
      without leaving the repo.
    </p>
    <div class="value-props">
      {valueProps.map((value) => (
        <article class="value-prop">
          <h3>{value.title}</h3>
          <p style="color:var(--text-muted);">{value.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="contribute" style="margin-top:3rem;">
    <p class="tag" style="margin-bottom:0.5rem;">Community stewardship</p>
    <h2 class="section-title">Keep every track exam-current</h2>
    <div class="card">
      <p style="color:var(--text-muted);">
        Found drift in an objective? Open a discussion, submit a PR, or add a lab scenario. The community keeps
        CertPrep aligned with the latest blueprints while sharing the exact workflows that engineers use in the field.
      </p>
      <div style="display:flex; gap:1rem; flex-wrap:wrap;">
        <a class="button" href="https://github.com/certforge/.github/blob/main/CONTRIBUTING.md" target="_blank" rel="noreferrer">
          Contribution Guide
        </a>
        <a class="button secondary" href="https://github.com/orgs/certforge/discussions/new?category=ideas" target="_blank" rel="noreferrer">
          Start a Discussion
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
