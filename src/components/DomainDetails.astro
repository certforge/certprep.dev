---
import type { Track } from "../data/tracks";

const { track }: { track: Track } = Astro.props;
---

<section class="domain-breakdown" aria-labelledby={`domains-${track.id}`}>
  <div style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; align-items:center;">
    <div>
      <p class="tag" style="margin:0;">{track.examCode}</p>
      <h3 id={`domains-${track.id}`} style="margin:0.45rem 0;">{track.title} · Exam Blueprint</h3>
      <p style="max-width:640px; color:var(--text-muted);">
        Weighted to the official blueprint so your study plan mirrors the scoring rubric. Each tile links to the docs, labs, or scripts that cover the domain.
      </p>
    </div>
    <div style="text-align:right;">
      <a class="button" href={`${track.repoUrl}/tree/main/demos`} target="_blank" rel="noreferrer">
        Browse Labs
      </a>
    </div>
  </div>

  <div class="domain-list">
    {track.domains.map((domain) => (
      <article class="domain-item">
        <h4>
          {domain.name} <span style="color:var(--text-muted); font-weight:400;">· {domain.weight}%</span>
        </h4>
        <div class="domain-weight-bar">
          <div class="domain-weight-fill" style={`width:${domain.weight}%`}></div>
        </div>
        <ul>
          {domain.focus.map((focus) => (
            <li>{focus}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>

  <div class="lab-cards">
    {track.labs.map((lab) => (
      <div class="lab-card">
        <span class={`lab-badge lab-badge-${lab.type}`}>{lab.type}</span>
        <strong>{lab.title}</strong>
        <p style="margin:0; color:var(--text-muted);">{lab.description}</p>
        <a href={`${track.repoUrl}/tree/main/${lab.path}`} target="_blank" rel="noreferrer">
          Open resource →
        </a>
      </div>
    ))}
  </div>
</section>
