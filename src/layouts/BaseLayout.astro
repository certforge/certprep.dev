---
import "../styles/global.css";
import { DEFAULT_DESCRIPTION, DEFAULT_OG_IMAGE, SITE_NAME, absoluteUrl } from "../lib/site";

const {
  title = `${SITE_NAME} | Learn. Build. Certify.`,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_OG_IMAGE,
  noindex = false,
  keywords = [],
  structuredData = []
} = Astro.props;

const canonicalUrl = Astro.url ? Astro.url.toString() : absoluteUrl("/");
const imageUrl = image.startsWith("http") ? image : absoluteUrl(image);
const robots = noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large";
const structuredDataBlocks = Array.isArray(structuredData) ? structuredData : [structuredData];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content={SITE_NAME} />
    <meta name="generator" content="Astro" />
    <meta name="theme-color" content="#f8fafc" />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/certprep-logo.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {structuredDataBlocks.filter(Boolean).map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body>
    <div class="page-shell">
      <a class="skip-link" href="#main-content">Skip to main content</a>
      <header>
        <div class="nav-shell">
          <div style="display:flex; align-items:center; gap:0.75rem;">
            <img src="/certprep-logo.svg" alt="CertPrep logo" width="48" height="48" />
            <div class="brand-lockup">
              <strong class="brand-title">CertPrep</strong>
              <div class="brand-tagline">Learn · Build · Certify</div>
            </div>
          </div>
          <nav class="nav-links" aria-label="Primary">
            <a href="/#tracks">Tracks</a>
            <div class="nav-dropdown">
              <button class="nav-trigger" type="button" aria-haspopup="true">
                Exam Prep Help
              </button>
              <div class="nav-menu" role="menu">
                <a role="menuitem" href="/exam-prep/gh-100">GH-100</a>
                <a role="menuitem" href="/exam-prep/gh-500">GH-500</a>
                <a role="menuitem" href="/exam-prep/gh-900">GH-900</a>
                <a role="menuitem" href="/exam-prep/ai-102">AI-102</a>
                <a role="menuitem" href="/exam-prep/aip-c01">AIP-C01</a>
                <a role="menuitem" href="/exam-prep">All blueprints</a>
              </div>
            </div>
            <a href="/#toolkit">Prep Toolkit</a>
            <a href="/#contribute">Contribute</a>
          </nav>
          <a class="button" href="https://github.com/certforge" target="_blank" rel="noreferrer">
            Explore GitHub
          </a>
        </div>
      </header>
      <main id="main-content" tabindex="-1">
        <slot />
      </main>
      <footer class="footer">
        Built by the CertPrep community. Licensed MIT.
      </footer>
    </div>
  </body>
</html>
